# Postiz integration env — copy to .env and fill in.
# .env is gitignored at the repo root; never commit real values.

# Self-hosted base. Change to public domain when behind reverse proxy.
POSTIZ_URL=http://localhost:5000

# Generate in Postiz UI → Settings → API → "Generate API key".
# This is the RAW key, NOT prefixed with "Bearer " — postiz-schedule.sh handles that.
POSTIZ_API_KEY=replace-me

# Channel IDs — fill once after connecting OAuth in Postiz UI.
# Get them with: ./postiz-list-integrations.sh | jq '.[] | {id, name, identifier}'

# Track A — dev brand
POSTIZ_CHANNEL_LINKEDIN_VENTRUE=
POSTIZ_CHANNEL_X_VENTRUE=
POSTIZ_CHANNEL_DEVTO_VENTRUE=

# Track B — WhatsApp-bot product (SMB)
POSTIZ_CHANNEL_INSTAGRAM_SMB=
POSTIZ_CHANNEL_FACEBOOK_SMB=
POSTIZ_CHANNEL_TIKTOK_SMB=
POSTIZ_CHANNEL_THREADS_SMB=

# Hermes notification target (for cron job summaries)
HERMES_DELIVER_TARGET=telegram
HERMES_DELIVER_CHAT_ID=
