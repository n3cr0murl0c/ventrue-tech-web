---
export interface MissionVisionCard {
  svgIcon: string;
  title: string;
  text: string;
  gradientFrom: string; // hex
  gradientTo: string;   // hex
}

export interface Props {
  mission: MissionVisionCard;
  vision: MissionVisionCard;
}

const { mission, vision } = Astro.props;
---

<section class="py-24 bg-gray-50 dark:bg-ventrue-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12">
      <!-- Mission -->
      <div class="card card-light dark:card-dark p-8">
        <div
          class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6"
          style={`background: linear-gradient(135deg, ${mission.gradientFrom}, ${mission.gradientTo})`}
        >
          <span class="text-white w-8 h-8" set:html={mission.svgIcon} />
        </div>
        <h2 class="text-2xl font-bold mb-4">{mission.title}</h2>
        <p class="text-gray-600 dark:text-gray-300">
          {mission.text}
        </p>
      </div>

      <!-- Vision -->
      <div class="card card-light dark:card-dark p-8">
        <div
          class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6"
          style={`background: linear-gradient(135deg, ${vision.gradientFrom}, ${vision.gradientTo})`}
        >
          <span class="text-white w-8 h-8" set:html={vision.svgIcon} />
        </div>
        <h2 class="text-2xl font-bold mb-4">{vision.title}</h2>
        <p class="text-gray-600 dark:text-gray-300">
          {vision.text}
        </p>
      </div>
    </div>
  </div>
</section>
