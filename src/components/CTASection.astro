---
export interface Props {
  title: string;
  description: string;
  ctaHref: string;
  ctaText: string;
}

const { title, description, ctaHref, ctaText } = Astro.props;
---

<section class="py-24 bg-gradient-to-r from-primary-500 to-ventrue-accent">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-4">
      {title}
    </h2>
    <p class="text-xl text-white/80 mb-8">
      {description}
    </p>
    <a
      href={ctaHref}
      class="inline-flex items-center gap-2 px-8 py-4 bg-white text-primary-600 font-semibold rounded-xl hover:bg-gray-100 transition-colors"
    >
      {ctaText}
      <svg
        class="w-5 h-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M17 8l4 4m0 0l-4 4m4-4H3"
        ></path>
      </svg>
    </a>
  </div>
</section>
