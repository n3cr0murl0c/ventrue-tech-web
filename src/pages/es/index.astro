---
import Layout from "@/layouts/Layout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import HeroSection from "@/components/HeroSection.astro";
import HeroSpotlight from "@/components/HeroSpotlight.astro";
import TrustStats from "@/components/TrustStats.astro";
import ServicesPreview from "@/components/ServicesPreview.astro";
import MissionVision from "@/components/MissionVision.astro";
import ValuesSection from "@/components/ValuesSection.astro";
import FeaturedProjects from "@/components/FeaturedProjects.astro";
import LatestArticles from "@/components/LatestArticles.astro";
import CTASection from "@/components/CTASection.astro";

// ── SVG icon fragments ────────────────────────────────────
const CLOUD_SVG =
  '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>';
const CODE_SVG =
  '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>';
const BOLT_SVG =
  '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>';
const MOBILE_SVG =
  '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>';
const EYE_SVG =
  '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>';
const SHIELD_SVG =
  '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>';
const CHECK_SVG =
  '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>';
const BULB_SVG =
  '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>';

// ── Hero spotlight items (auto-rotating featured projects + blog posts) ──
const SPOTLIGHT_ITEMS = [
  {
    kind: "PROYECTO",
    title: "FinHelper",
    description:
      "Calculadora financiera en Flutter con monetización AdMob y backend .NET.",
    href: "/es/projects/finhelper",
    meta: "Flutter · .NET · AdMob",
    ctaText: "Ver proyecto ›",
    badge: "F",
  },
  {
    kind: "ARTÍCULO",
    title: "Cómo Mejorar Tu Código en 2026",
    description:
      "Mejores prácticas, herramientas y técnicas para elevar tu nivel como desarrollador.",
    href: "/es/blog/mejorar-codigo-2026",
    meta: "8 min · 7 Feb 2026",
    ctaText: "Leer artículo ›",
    badge: "C",
  },
  {
    kind: "SERVICIO",
    title: "IA & Automatización",
    description:
      "LLMs, workflows agénticos y pipelines de contenido. Construimos y operamos.",
    href: "/es/servicios",
    meta: "3–12 semanas · Cotización a medida",
    ctaText: "Conversemos ›",
    badge: "IA",
  },
  {
    kind: "ARTÍCULO",
    title: "TypeScript Tips Avanzados",
    description:
      "Domina TypeScript con consejos avanzados que te ahorrarán horas de debugging.",
    href: "/es/blog/typescript-avanzado",
    meta: "6 min · 7 Feb 2026",
    ctaText: "Leer artículo ›",
    badge: "T",
  },
];
---

<Layout
  title="Inicio"
  lang="es"
>
  <Navbar />

  <main>
    <HeroSection
      statusText="Estado del Sistema: Óptimo"
      headingLine1="Software, cloud"
      headingAccent="y automatización"
      headingLine2="como servicio."
      description="Una práctica de ingeniería que diseña, construye y opera sistemas de extremo a extremo. Tu equipo de ingeniería bajo demanda — software, arquitectura cloud, DevOps e IA."
      ctaHref="/es/servicios"
      ctaText="Ver Servicios"
      secondaryHref="/es/contact"
      secondaryText="Conversemos"
    >
      <HeroSpotlight
        slot="right-panel"
        items={SPOTLIGHT_ITEMS}
        figLabel="FIG 01 // BROADCAST_FEED"
      />
    </HeroSection>

    <TrustStats
      stats={[
        { value: "50+", label: "Proyectos Completados" },
        { value: "98%", label: "Satisfacción del Cliente" },
        { value: "3+", label: "Años de Experiencia" },
        { value: "5+", label: "Países Atendidos" },
      ]}
    />

    <ServicesPreview
      title="Nuestros Servicios"
      subtitle="Soluciones digitales integrales diseñadas para impulsar tu negocio"
      viewAllHref="/es/servicios"
      viewAllText="Ver Todos los Servicios"
      services={[
        {
          title: "Arquitectura Cloud",
          description: "Diseño y migración cloud-native sobre AWS o Azure.",
          href: "/es/servicios",
          svgIcon: CLOUD_SVG,
          gradientFrom: "#0ea5e9",
          gradientTo: "#0284c7",
        },
        {
          title: "DevOps & SRE",
          description: "CI/CD, IaC, observabilidad y on-call. Proyecto o retainer.",
          href: "/es/servicios",
          svgIcon: CODE_SVG,
          gradientFrom: "#00d4ff",
          gradientTo: "#0ea5e9",
        },
        {
          title: "IA & Automatización",
          description: "LLMs, workflows agénticos y pipelines de contenido.",
          href: "/es/servicios",
          svgIcon: BOLT_SVG,
          gradientFrom: "#7c3aed",
          gradientTo: "#00d4ff",
        },
        {
          title: "Apps Móviles",
          description: "iOS y Android con Flutter o React Native + backend.",
          href: "/es/servicios",
          svgIcon: MOBILE_SVG,
          gradientFrom: "#0284c7",
          gradientTo: "#7c3aed",
        },
      ]}
    />

    <MissionVision
      mission={{
        svgIcon: BOLT_SVG,
        title: "Nuestra Misión",
        text: "Ayudar a empresas y equipos técnicos a construir, escalar y operar software de calidad — sin tener que ensamblar tres proveedores distintos.",
        gradientFrom: "#0ea5e9",
        gradientTo: "#0284c7",
      }}
      vision={{
        svgIcon: EYE_SVG,
        title: "Nuestra Visión",
        text: "Ser la práctica de ingeniería de referencia en Latinoamérica para empresas que necesitan velocidad sin sacrificar arquitectura.",
        gradientFrom: "#00d4ff",
        gradientTo: "#0ea5e9",
      }}
    />

    <ValuesSection
      title="Nuestros Valores"
      subtitle="Los valores que nos definen y guían cada decisión que tomamos."
      values={[
        {
          svgIcon: SHIELD_SVG,
          title: "Responsabilidad",
          description: "Asumimos el resultado de extremo a extremo — desde la arquitectura hasta el page de las 3 AM.",
          gradientFrom: "#00d4ff",
          gradientTo: "#0ea5e9",
        },
        {
          svgIcon: CHECK_SVG,
          title: "Calidad",
          description: "Escribimos código, escribimos tests y escribimos runbooks. Los tres.",
          gradientFrom: "#0ea5e9",
          gradientTo: "#0284c7",
        },
        {
          svgIcon: EYE_SVG,
          title: "Transparencia",
          description: "Estimaciones, alcance y tradeoffs honestos — aunque cueste el contrato.",
          gradientFrom: "#7c3aed",
          gradientTo: "#00d4ff",
        },
        {
          svgIcon: BULB_SVG,
          title: "Pragmatismo",
          description: "La arquitectura más simple que resuelve el problema real, no la más impresionante.",
          gradientFrom: "#0284c7",
          gradientTo: "#7c3aed",
        },
      ]}
    />

    <FeaturedProjects
      title="Últimos Proyectos"
      viewAllHref="/es/projects"
      viewAllText="Ver todos"
      projects={[
        {
          href: "/es/projects/finhelper",
          gradientFrom: "#0ea5e9",
          gradientTo: "#00d4ff",
          imageContent: "F",
          title: "FinHelper App",
          description: "Calculadora financiera en Flutter con monetización AdMob.",
          technologies: ["Flutter", ".NET", "AdMob"],
        },
      ]}
    />

    <LatestArticles
      title="Últimos Artículos"
      viewAllHref="/es/blog"
      viewAllText="Ver todos"
      articles={[
        {
          href: "/es/blog/mejorar-codigo-2026",
          date: "7 Feb 2026",
          readTime: "8 min lectura",
          title: "Cómo Mejorar Tu Código en 2026",
          description: "Descubre las mejores prácticas, herramientas y técnicas para elevar tu nivel como desarrollador.",
          readMoreText: "Leer más",
        },
        {
          href: "/es/blog/typescript-avanzado",
          date: "7 Feb 2026",
          readTime: "6 min lectura",
          title: "TypeScript Tips Avanzados",
          description: "Domina TypeScript con estos consejos avanzados que te ahorrarán horas de debugging.",
          readMoreText: "Leer más",
        },
      ]}
    />

    <CTASection
      title="¿Listo para transformar tu proyecto?"
      description="Hablemos sobre cómo podemos ayudarte a alcanzar tus objetivos tecnológicos."
      ctaHref="/es/contact"
      ctaText="Contáctanos Ahora"
    />
  </main>

  <Footer />
</Layout>
