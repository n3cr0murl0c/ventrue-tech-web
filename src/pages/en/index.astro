---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import HeroSection from '@/components/HeroSection.astro';
import HeroSpotlight from '@/components/HeroSpotlight.astro';
import MissionVision from '@/components/MissionVision.astro';
import ValuesSection from '@/components/ValuesSection.astro';
import FeaturedProjects from '@/components/FeaturedProjects.astro';
import LatestArticles from '@/components/LatestArticles.astro';
import CTASection from '@/components/CTASection.astro';

// ── SVG icon fragments ────────────────────────────────────
const BOLT_SVG =
  '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>';
const EYE_SVG =
  '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>';

// ── Hero spotlight items (auto-rotating featured projects + blog posts) ──
const SPOTLIGHT_ITEMS = [
  {
    kind: "PROJECT",
    title: "FinHelper",
    description:
      "Financial calculator in Flutter with AdMob monetization and a .NET backend.",
    href: "/en/projects/finhelper",
    meta: "Flutter · .NET · AdMob",
    ctaText: "Open project ›",
    badge: "F",
  },
  {
    kind: "ARTICLE",
    title: "How to Improve Your Code in 2026",
    description:
      "Best practices, tools, and techniques to elevate your developer skills.",
    href: "/en/blog/mejorar-codigo-2026",
    meta: "8 min · Feb 7, 2026",
    ctaText: "Read article ›",
    badge: "C",
  },
  {
    kind: "SERVICE",
    title: "AI & Automation",
    description:
      "LLMs, agentic workflows, and content pipelines. We build and operate.",
    href: "/en/servicios",
    meta: "3–12 weeks · Custom quote",
    ctaText: "Let's talk ›",
    badge: "AI",
  },
  {
    kind: "ARTICLE",
    title: "Advanced TypeScript Tips",
    description:
      "Master TypeScript with advanced tips that will save you hours of debugging.",
    href: "/en/blog/typescript-avanzado",
    meta: "6 min · Feb 7, 2026",
    ctaText: "Read article ›",
    badge: "T",
  },
];
---

<Layout title="Home" lang="en">
  <Navbar />
  
  <main>
    <HeroSection
      statusText="System Status: Optimal"
      headingLine1="Software, cloud,"
      headingAccent="and automation"
      headingLine2="delivered as a service."
      description="An engineering practice that designs, builds, and operates end-to-end systems. Your on-demand engineering team — software, cloud architecture, DevOps, and AI."
      ctaHref="/en/servicios"
      ctaText="View Services"
      secondaryHref="/en/contact"
      secondaryText="Let's Talk"
    >
      <HeroSpotlight
        slot="right-panel"
        items={SPOTLIGHT_ITEMS}
        figLabel="FIG 01 // BROADCAST_FEED"
      />
    </HeroSection>

    <MissionVision
      mission={{
        svgIcon: BOLT_SVG,
        title: "Our Mission",
        text: "Help companies and technical teams build, scale, and operate quality software — without having to assemble three separate vendors.",
        gradientFrom: "#0ea5e9",
        gradientTo: "#0284c7",
      }}
      vision={{
        svgIcon: EYE_SVG,
        title: "Our Vision",
        text: "Be the reference engineering practice in Latin America for companies that need speed without sacrificing architecture.",
        gradientFrom: "#00d4ff",
        gradientTo: "#0ea5e9",
      }}
    />

    <ValuesSection
      title="Our Values"
      subtitle="The values that define us and guide every decision we make."
      values={[
        {
          emoji: "🎯",
          title: "Ownership",
          description: "We own the outcome end-to-end — from architecture to 3 AM pages.",
        },
        {
          emoji: "⭐",
          title: "Quality",
          description: "We write code, write tests, and write runbooks. All three.",
        },
        {
          emoji: "🔍",
          title: "Transparency",
          description: "Honest estimates and tradeoffs — even when it costs us the engagement.",
        },
        {
          emoji: "⚙️",
          title: "Pragmatism",
          description: "The simplest architecture that solves the problem, not the most impressive one.",
        },
      ]}
    />

    <FeaturedProjects
      title="Latest Projects"
      viewAllHref="/en/projects"
      viewAllText="View all"
      projects={[
        {
          href: "/en/projects/finhelper",
          gradientFrom: "#0ea5e9",
          gradientTo: "#00d4ff",
          imageContent: "F",
          title: "FinHelper App",
          description: "Financial calculator in Flutter with AdMob monetization.",
          technologies: ["Flutter", ".NET", "AdMob"],
        },
      ]}
    />

    <LatestArticles
      title="Latest Articles"
      viewAllHref="/en/blog"
      viewAllText="View all"
      articles={[
        {
          href: "/en/blog/mejorar-codigo-2026",
          date: "Feb 7, 2026",
          readTime: "8 min read",
          title: "How to Improve Your Code in 2026",
          description: "Discover the best practices, tools, and techniques to elevate your developer skills.",
          readMoreText: "Read more",
        },
        {
          href: "/en/blog/typescript-avanzado",
          date: "Feb 7, 2026",
          readTime: "6 min read",
          title: "Advanced TypeScript Tips",
          description: "Master TypeScript with these advanced tips that will save you hours of debugging.",
          readMoreText: "Read more",
        },
      ]}
    />

    <CTASection
      title="Ready to transform your project?"
      description="Let's talk about how we can help you achieve your technology goals."
      ctaHref="/en/contact"
      ctaText="Contact Us Now"
    />
  </main>

  <Footer />
</Layout>
